{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShadowProofMathlibRetrievalInput",
  "type": "object",
  "properties": {
    "request_id": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domain_dirs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "index_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "include_prompt_context": {
      "type": "boolean"
    },
    "max_prompt_chars": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 20000
    }
  },
  "additionalProperties": false
}
