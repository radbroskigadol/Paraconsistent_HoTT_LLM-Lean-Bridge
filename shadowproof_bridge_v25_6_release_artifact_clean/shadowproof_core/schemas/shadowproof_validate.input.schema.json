{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShadowProofValidateInput",
  "type": "object",
  "required": [
    "request_id"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "validate"
      ],
      "default": "validate"
    },
    "nl_problem": {
      "type": "object",
      "properties": {
        "context": {
          "type": "string"
        },
        "theorem": {
          "type": "string"
        },
        "proof": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "lean_code": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string",
          "enum": [
            "lean4"
          ]
        },
        "imports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allow_sorry": {
          "type": "boolean"
        },
        "theorem_name": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "properties": {
        "max_iterations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        },
        "allow_theorem_mutation": {
          "type": "boolean"
        },
        "security_level": {
          "type": "string",
          "enum": [
            "conservative",
            "permissive"
          ]
        },
        "return_code": {
          "type": "boolean"
        },
        "return_proof_graph": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "required": [
        "nl_problem"
      ]
    },
    {
      "required": [
        "lean_code"
      ]
    }
  ],
  "additionalProperties": false
}
