# Copy to deploy/.env for local pilot only, or inject equivalent values through
# Docker/Kubernetes/secret-manager facilities. Do not commit real values.
SHADOWPROOF_BEARER_TOKENS=replace-with-random-token:default
SHADOWPROOF_POSTGRES_PASSWORD=replace-with-random-password
SHADOWPROOF_POSTGRES_DSN=postgresql://shadow:replace-with-random-password@postgres:5432/shadow
