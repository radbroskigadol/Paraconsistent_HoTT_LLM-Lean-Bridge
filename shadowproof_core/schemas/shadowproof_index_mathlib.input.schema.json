{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShadowProofIndexMathlibInput",
  "type": "object",
  "required": [
    "source_dirs",
    "output_path"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "source_dirs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_path": {
      "type": "string"
    },
    "max_files": {
      "type": "integer",
      "minimum": 1
    },
    "include_private": {
      "type": "boolean"
    },
    "default_import": {
      "type": "string"
    },
    "build_dependency_graph": {
      "type": "boolean"
    },
    "lsh_bucket_bits": {
      "type": "integer",
      "minimum": 4,
      "maximum": 64
    }
  },
  "additionalProperties": false
}
