{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ShadowProofShadowHoTTEvalSuite",
  "type": "object",
  "required": [
    "suite_id",
    "cases"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "suite_id": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_id"
        ],
        "properties": {
          "case_id": {
            "type": "string"
          },
          "input_file": {
            "type": "string"
          },
          "input": {
            "type": "object"
          },
          "expect_lane": {
            "type": "string"
          },
          "expect_verdict": {
            "type": "string"
          },
          "expect_repairability": {
            "type": "string"
          },
          "expect_patch_kind": {
            "type": "string"
          },
          "expect_theorem_safe": {
            "type": "boolean"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
